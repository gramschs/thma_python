RENZE_OBEN_MM:\n        niO_1 = niO_1 + 1\n    else:\n        iO_1 = iO_1 + 1\n\n# Verarbeitung: Schicht 2\niO_2 = 0\nniO_2 = 0\nfor d in schicht_2_mm:\n    if d < GRENZE_UNTEN_MM or d > GRENZE_OBEN_MM:\n        niO_2 = niO_2 + 1\n    else:\n        iO_2 = iO_2 + 1\n\nquote_1 = niO_1 / len(schicht_1_mm) * 100\nquote_2 = niO_2 / len(schicht_2_mm) * 100\n\n# Ausgabe\nprint(f\"Schicht 1:  {iO_1:2d} iO, {niO_1:2d} niO,  Ausschussquote: {quote_1:4.1f} %\")\nprint(f\"Schicht 2:  {iO_2:2d} iO, {niO_2:2d} niO,  Ausschussquote: {quote_2:4.1f} %\")\n\nif quote_1 < quote_2:\n    print('Schicht 1 hat besser abgeschnitten.')\nelif quote_2 < quote_1:\n    print('Schicht 2 hat besser abgeschnitten.')\nelse:\n    print('Beide Schichten sind gleich gut.')\n\nfig = px.bar(x=[\"Schicht 1 iO\", \"Schicht 1 niO\", \"Schicht 2 iO\", \"Schicht 2 niO\"],\n             y=[iO_1, niO_1, iO_2, niO_2],\n             labels={\"x\": \"Klassifizierung\", \"y\": \"Anzahl Schrauben\"},\n             title=\"Qualitätskontrolle: Vergleich beider Schichten\")\nfig.show()","position":{"start":{"line":217,"column":1},"end":{"line":268,"column":1}},"key":"pFOfyEmGbZ"}],"class":"tip dropdown","key":"jFAIoUrOjJ"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Musterlösung Szenario B","position":{"start":{"line":271,"column":1},"end":{"line":271,"column":1}},"key":"BQvXJ6suG6"}],"key":"bHKtZmsZrf"},{"type":"code","lang":"python","value":"import plotly.express as px\n\n# Eingabe\ntemperaturen_C = [12.3, 14.1, 11.8, 15.6, 18.2, 20.4, 19.7,\n                  17.3, 16.8, 14.9, 13.2, 11.5, 10.8, 12.1,\n                  15.4, 17.9, 21.3, 23.6, 22.8, 20.1, 18.5,\n                  16.2, 14.7, 13.9, 15.1, 17.4, 19.8, 22.5]\ntage = list(range(1, 29))\n\n# Verarbeitung\nanzahl_kalt = 0\nanzahl_mild = 0\nanzahl_warm = 0\n\nmax_temp = temperaturen_C[0]\nmin_temp = temperaturen_C[0]\nmax_tag = 1\nmin_tag = 1\n\nfor i in range(len(temperaturen_C)):\n    t = temperaturen_C[i]\n    tag = tage[i]\n\n    if t < 10:\n        anzahl_kalt = anzahl_kalt + 1\n    elif t < 20:\n        anzahl_mild = anzahl_mild + 1\n    else:\n        anzahl_warm = anzahl_warm + 1\n\n    if t > max_temp:\n        max_temp = t\n        max_tag = tag\n    if t < min_temp:\n        min_temp = t\n        min_tag = tag\n\n# Ausgabe\nprint(f\"Kalte Tage:  {anzahl_kalt:2d}\")\nprint(f\"Milde Tage:  {anzahl_mild:2d}\")\nprint(f\"Warme Tage:  {anzahl_warm:2d}\")\nprint(f\"Wärmster Tag:  Tag {max_tag:2d} mit {max_temp:.1f} °C\")\nprint(f\"Kältester Tag: Tag {min_tag:2d} mit {min_temp:.1f} °C\")\n\nfig = px.line(x=tage, y=temperaturen_C,\n              labels={\"x\": \"Tag\", \"y\": \"Temperatur in °C\"},\n              title=\"Tageshöchsttemperaturen über 4 Wochen\")\nfig.show()","position":{"start":{"line":274,"column":1},"end":{"line":323,"column":1}},"key":"t4LAOanNZd"}],"class":"tip dropdown","key":"ZlctaYUzMb"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Musterlösung Szenario C","position":{"start":{"line":326,"column":1},"end":{"line":326,"column":1}},"key":"nZR6xO71Yf"}],"key":"VW6Pr7llnO"},{"type":"code","lang":"python","value":"import plotly.express as px\n\n# Eingabe\nfahrzeuge = [\"LW-01\", \"LW-02\", \"LW-03\", \"LW-04\", \"LW-05\",\n             \"LW-06\", \"LW-07\", \"LW-08\", \"LW-09\", \"LW-10\"]\nverbrauch_l = [48.2, 61.5, 52.3, 44.8, 70.1, 55.6, 49.3, 63.7, 51.2, 58.9]\nstrecke_km  = [520,  610,  480,  550,  590,  500,  530,  620,  490,  570]\n\n# Verarbeitung\nverbrauch_100km = []\nanzahl_effizient = 0\nanzahl_normal = 0\nanzahl_ineffizient = 0\n\nmin_verbrauch = 999.9\nmax_verbrauch = 0.0\nbestes_fahrzeug = \"\"\nschlechtestes_fahrzeug = \"\"\n\nfor i in range(len(fahrzeuge)):\n    v = verbrauch_l[i] / strecke_km[i] * 100\n    verbrauch_100km.append(v)\n\n    if v < 8.0:\n        klasse = 'effizient'\n        anzahl_effizient = anzahl_effizient + 1\n    elif v < 11.0:\n        klasse = 'normal'\n        anzahl_normal = anzahl_normal + 1\n    else:\n        klasse = 'ineffizient'\n        anzahl_ineffizient = anzahl_ineffizient + 1\n\n    print(f\"{fahrzeuge[i]}: {v:5.1f} L/100km  →  {klasse}\")\n\n    if v < min_verbrauch:\n        min_verbrauch = v\n        bestes_fahrzeug = fahrzeuge[i]\n    if v > max_verbrauch:\n        max_verbrauch = v\n        schlechtestes_fahrzeug = fahrzeuge[i]\n\n# Ausgabe\nprint(f\"\\nEffizient:    {anzahl_effizient:2d} Fahrzeuge\")\nprint(f\"Normal:       {anzahl_normal:2d} Fahrzeuge\")\nprint(f\"Ineffizient:  {anzahl_ineffizient:2d} Fahrzeuge\")\nprint(f\"Effizientestes Fahrzeug:     {bestes_fahrzeug} mit {min_verbrauch:.1f} L/100km\")\nprint(f\"Ineffizienstestes Fahrzeug:  {schlechtestes_fahrzeug} mit {max_verbrauch:.1f} L/100km\")\n\nfig = px.bar(x=fahrzeuge, y=verbrauch_100km,\n             labels={\"x\": \"Fahrzeug\", \"y\": \"Verbrauch in L/100km\"},\n             title=\"Kraftstoffverbrauch der Fahrzeugflotte\")\nfig.show()","position":{"start":{"line":329,"column":1},"end":{"line":383,"column":1}},"key":"RKFE1bFBfr"}],"class":"tip dropdown","key":"BaoqPzfJJX"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Musterlösung Szenario D","position":{"start":{"line":386,"column":1},"end":{"line":386,"column":1}},"key":"UXDJQ3i6GT"}],"key":"wEzyQSyA3A"},{"type":"code","lang":"python","value":"import numpy as np\nimport plotly.express as px\n\n# Eingabe\nglueckszahl = int(input('Ihre Glückszahl (0 bis 36): '))\neinsatz_eur = float(input('Ihr Einsatz pro Runde in EUR: '))\nANZAHL_RUNDEN = 100\nSTARTVERMOEGEN_EUR = 100.0\n\n# Verarbeitung\nkontostand_eur = STARTVERMOEGEN_EUR\nkontostand_verlauf = [STARTVERMOEGEN_EUR]\nanzahl_treffer = 0\n\nfor i in range(ANZAHL_RUNDEN):\n    ergebnis = np.random.randint(0, 37)\n\n    if ergebnis == glueckszahl:\n        kontostand_eur = kontostand_eur + 35 * einsatz_eur\n        anzahl_treffer = anzahl_treffer + 1\n    else:\n        kontostand_eur = kontostand_eur - einsatz_eur\n\n    kontostand_verlauf.append(kontostand_eur)\n\ngewinn_verlust = kontostand_eur - STARTVERMOEGEN_EUR\n\n# Ausgabe\nprint(f\"Startvermögen:   {STARTVERMOEGEN_EUR:8.2f} EUR\")\nprint(f\"Endvermögen:     {kontostand_eur:8.2f} EUR\")\nprint(f\"Gewinn/Verlust:  {gewinn_verlust:8.2f} EUR\")\nprint(f\"Anzahl Treffer:  {anzahl_treffer:4d} von {ANZAHL_RUNDEN}\")\n\nfig = px.line(x=list(range(ANZAHL_RUNDEN + 1)), y=kontostand_verlauf,\n              labels={\"x\": \"Runde\", \"y\": \"Kontostand in EUR\"},\n              title=f\"Roulette: Kontostandverlauf über {ANZAHL_RUNDEN} Runden\")\nfig.show()","position":{"start":{"line":389,"column":1},"end":{"line":427,"column":1}},"key":"MQ6raCLrx6"}],"class":"tip dropdown","key":"McvYK32zCL"}],"key":"iP06Ij0MNn"}],"key":"awnguAfRCP"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Übungen","url":"/chapter07-sec03","group":"7. Komplexe Entscheidungen"},"next":{"title":"9.1 Funktionen selbst schreiben","url":"/chapter09-sec01","group":"9. Funktionen"}}},"domain":"http://localhost:3000"}